<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="4" author="reminder">
        <createIndex indexName="idx_reminders_user_id" tableName="reminders">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="5" author="reminder">
        <createIndex indexName="idx_reminders_remind" tableName="reminders">
            <column name="remind"/>
        </createIndex>
    </changeSet>

    <changeSet id="6" author="reminder">
        <createIndex indexName="idx_reminders_status" tableName="reminders">
            <column name="remind_status"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>